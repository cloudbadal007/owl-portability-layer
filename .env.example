# Copy to .env and fill in for live adapter runs. Demos and tests do not require these.

# Palantir Foundry
FOUNDRY_BASE_URL=https://your-stack.palantirfoundry.com
FOUNDRY_TOKEN=

# Microsoft Fabric IQ
FABRIC_WORKSPACE_ID=
FABRIC_IQ_ONTOLOGY_ID=
FABRIC_TOKEN=

# Generic MCP gateway (JSON-RPC)
MCP_SERVER_URL=http://127.0.0.1:8765/rpc

# AWS AgentCore (required for production mode only)
# All demos work without these in simulation_mode=True
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=us-east-1
